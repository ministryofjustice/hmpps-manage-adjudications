<html>
<head>
    <style>
        body {
            -webkit-print-color-adjust: exact;
            font-family: arial;
        }
        h1 {
            font-size: 18px;
        }
        h2 {
            font-size: 10px;
            font-weight: normal;
        }

        .adjudication-pdf-header {
            background-color: #d8d8d8;
            width: 100%;
            padding: 0px 30px;
        }

        .adjudication-pdf-header-official {
            text-align: center;
            margin: 5px 0 0 0;
        }

        .adjudication-pdf-header-main {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .adjudication-pdf-header-bold {
            font-weight: bold;
        }
        .adjudication-pdf-header-normal {
            font-weight: normal;
        }
    </style>
</head>
<body>
<div class="adjudication-pdf-header">
    <h2 class="adjudication-pdf-header-official">Official</h2>

    <div class="adjudication-pdf-header-main">
        <h1>DIS3 Prepare for and record an adjudication hearing</h1>

        <h2>
            <span class="adjudication-pdf-header-bold">Charge number:</span>
            <span class="adjudication-pdf-header-normal">{{ chargeNumber }}</span>
        </h2>
    </div>
</div>
</body>
</html>
