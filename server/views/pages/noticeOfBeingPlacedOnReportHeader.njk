<html>
<head>
    <style>
        body {
            -webkit-print-color-adjust: exact;
            font-family: arial;
        }
        h1 {
            font-size: 18px;
        }
        h2 {
            font-size: 10px;
            font-weight: normal;
        }

        .adjudication-pdf-header {
            background-color: #d8d8d8;
            width: 100%;
            padding: 0px 30px;
        }

        .adjudication-pdf-header-official {
            text-align: center;
            margin: 5px 0 0 0;
        }

        .adjudication-pdf-header-main {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .adjudication-pdf-header-bold {
            font-weight: bold;
        }
        .adjudication-pdf-header-normal {
            font-weight: normal;
        }
    </style>
</head>

<div class="adjudication-pdf-header">
    <h2 class="adjudication-pdf-header-official">Official</h2>

    <div class="adjudication-pdf-header-main">
        {% if isPrisonerCopy %}
        <h1>DIS1 and 2 Notice of being placed on report</h1>
        {% else %}
        <h1>DIS1 Notice of being placed on report</h1>
        {% endif %}
        <h2>
            <span class="adjudication-pdf-header-bold">Charge number:</span>
            <span class="adjudication-pdf-header-normal">{{ chargeNumber }}</span>
        </h2>
    </div>
</div>
</body>
</html>
