        <div class="adjudication-pdf-section-date-signature__item ">
          <p class='govuk-!-margin-top-3'>Date (DD/MM/YYYY)</p>
          <input type='text' class='adjudication-pdf-input adjudication-pdf-input__square'><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'>
          <span>
            <strong> / </strong>
          </span><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'>
          <span>
            <strong> / </strong>
          </span><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'><input type='text'  class='adjudication-pdf-input adjudication-pdf-input__square'>
        </div>
      </div>
    </section>

      {% for hearing in range(0, 3) %}
